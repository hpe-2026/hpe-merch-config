# Ensure consistent line endings across platforms
* text=auto eol=lf

# Shell scripts must always use LF
*.sh text eol=lf

# Docker files must use LF
Dockerfile text eol=lf
docker-compose.yml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# JS/JSON/Config
*.js text eol=lf
*.mjs text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf

# Python
*.py text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
